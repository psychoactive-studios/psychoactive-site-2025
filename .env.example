# Psychoactive Studios — local env template
#
# Copy this file to `.env` at the repo root and fill in the values below.
# The real values live in the Vercel project env vars (Settings →
# Environment Variables). `.env` itself is gitignored so secrets don't
# get committed.

# Your local dev URL. Leave as-is unless running on a non-standard port.
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Strapi CMS — required for the homepage, /work, /content-hub pages.
# Get the production URL + API key from Vercel env vars.
NUXT_PUBLIC_STRAPI_BASE_URL=
STRAPI_API_KEY=

# Strapi preview integration — only needed if you're testing the
# /preview/work/[slug] or /preview/content-hub/[slug] routes locally.
# Can be left blank otherwise.
STRAPI_PREVIEW_URL=
STRAPI_PREVIEW_SECRET=

# Design Audit feature — required for the /design-audit page.
# Claude API key from console.anthropic.com (pay as you go, ~$0.05/audit).
ANTHROPIC_API_KEY=

# CRM Supabase — lead data for design audit submissions lands here.
# Get these from the Psychoactive CRM's Vercel env vars (or the Supabase
# project dashboard). Use the service_role key so the server can write.
SUPABASE_CRM_URL=
SUPABASE_CRM_SERVICE_KEY=
